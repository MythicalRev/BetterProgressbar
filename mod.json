{
	"geode": "5.7.1",
	"gd": {
		"win": "2.2081",
		"android": "2.2081",
		"mac": "2.2081",
		"ios": "2.2081"
	},
	"id": "mythicalrev.better-progressbar",
	"name": "Better Progress Bar",
	"version": "v1.0.4",
	"developer": "MythicalRev",
	"description": "Adds Custom Progress Bar Images and More!",
	"dependencies": {
		"geode.node-ids": ">=v1.20.0"
	},
	"resources": {
        "sprites": [
            "resources/*.png"
        ]
    },
	"tags": [
		"enhancement",
		"customization",
		"interface"
	],
	"links": {
		"source": "https://github.com/MythicalRev/BetterProgressbar",
		"homepage": "https://myth.gay"
	},
	"issues": {
		"info": "Report an issue",
		"url": "https://github.com/MythicalRev/BetterProgressbar/issues"
	},
	"settings": {
		"customBar": {
			"type": "file",
			"name": "Custom Bar Image",
			"default": "Please pick an image file.",
			"control": {
				"dialog": "open",
				"filters": [
					{
						"files": ["*.png", "*.jpg", "*.jpeg"],
						"description": "Image files"
					}
				]
			}
		}
	}
}
